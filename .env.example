# Copy this file to .env and fill in your own values.

DATABASE_URL=file:./db/custom.db

# --- Supabase ---
# From your Supabase project: Project Settings → API.
# FOUNDATION ONLY — no login/signup flow reads these yet (see
# src/lib/supabase/README.md). The app runs fully in guest mode with
# every one of these left blank.

# Project URL, e.g. https://xyzcompany.supabase.co
# Safe to expose to the browser (NEXT_PUBLIC_ prefix required by Next.js).
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key. Safe to expose to the browser — Supabase enforces
# access via Row Level Security, not by keeping this secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret "service role" key. SERVER-ONLY — bypasses Row Level Security.
# Never prefix this with NEXT_PUBLIC_ and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Service ---
# Powers the AI Chat feature (src/components/chat/, served at /chat),
# connected via POST /api/ai/chat (see src/lib/ai/README.md). The app,
# and the chat page itself, run fully with all four left blank, exactly
# like the Supabase section above — the chat UI just shows a clear
# "not configured" notice instead of a reply.

# Provider name to resolve, e.g. "openai", "anthropic". Leave blank/"none"
# to keep using the safe no-op default (src/lib/ai/providers/noopProvider.ts).
AI_PROVIDER=

# Model identifier to request from the configured provider, e.g. "gpt-4o-mini".
AI_MODEL=

# Secret API key for the configured provider. SERVER-ONLY — never prefix
# this with NEXT_PUBLIC_ and never expose it to the browser. Do not commit
# a real value here.
AI_API_KEY=

# Optional custom API base URL, for a self-hosted or proxied endpoint.
AI_BASE_URL=

# --- AI Providers: OpenAI / Claude / Gemini ---
# Modular and connected (see src/lib/ai/README.md) — each provider makes
# a real API call to its own vendor once configured. Each vendor reads
# its own dedicated variables below, independently of the generic
# AI_MODEL/AI_API_KEY/AI_BASE_URL above, so more than one vendor's config
# can be present at the same time. Set AI_PROVIDER to "openai", "claude",
# or "gemini" to select which one AIService resolves to — switching later
# is just changing this one value and restarting the server. Do not
# commit real values here.

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# Gemini (Google) — https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_BASE_URL=

# --- OCR Service ---
# Architecture-only foundation for three OCR features — Image to Text,
# Receipt Reading, and Math Image Recognition (see src/lib/ocr/README.md).
# Unlike the AI Service section above, NO vendor OCR provider is
# implemented or connected — providers/index.ts's registry has exactly
# one entry ("none" -> the safe NoopOCRProvider). Every one of these is
# left blank on purpose; the three OCR API routes
# (src/app/api/ocr/image-to-text, /receipt, /math) still work correctly
# with nothing configured — they return a clear "not configured" error
# instead of doing anything silently wrong.

# Provider name to resolve. No value currently resolves to anything
# other than the no-op default (src/lib/ocr/providers/noopProvider.ts) —
# present for a future real provider to be registered against.
OCR_PROVIDER=

# Model/engine identifier a future provider would request.
OCR_MODEL=

# Secret API key for a future configured provider. SERVER-ONLY — never
# prefix this with NEXT_PUBLIC_ and never expose it to the browser. Not
# read by anything in this task's scope.
OCR_API_KEY=

# Optional custom API base URL for a future self-hosted or proxied OCR endpoint.
OCR_BASE_URL=
